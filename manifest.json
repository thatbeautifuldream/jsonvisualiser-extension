{
  "manifest_version": 3,
  "name": "JSON Visualiser",
  "version": "0.1.0",
  "description": "Replace raw JSON pages with the JSON Visualiser app.",
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
