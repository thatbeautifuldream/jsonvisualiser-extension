{
  "manifest_version": 3,
  "name": "JSON Visualiser",
  "version": "0.1.0",
  "description": "Replace raw JSON pages with the JSON Visualiser app.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
